<Page x:Class="Mulkamonov_Shirokova_523.Pages.Page2"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Page2" Height="500" Width="700">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="250"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" 
                   Text="Условная функция a" 
                   FontSize="16" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="10"/>

        <Label Grid.Row="1" Grid.Column="0" Content="x:" Margin="5"/>
        <TextBox x:Name="txtX" Grid.Row="1" Grid.Column="1" Height="30" Margin="5" Padding="5"/>

        <Label Grid.Row="2" Grid.Column="0" Content="y:" Margin="5"/>
        <TextBox x:Name="txtY" Grid.Row="2" Grid.Column="1" Height="30" Margin="5" Padding="5"/>

        <Label Grid.Row="3" Grid.Column="0" Content="f(x):" Margin="5"/>
        <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Margin="5">
            <RadioButton x:Name="rbSh" Content="sh(x)" GroupName="fx" Margin="5" IsChecked="True"/>
            <RadioButton x:Name="rbX2" Content="x²" GroupName="fx" Margin="5"/>
            <RadioButton x:Name="rbExp" Content="eˣ" GroupName="fx" Margin="5"/>
        </StackPanel>

        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="5,10,-85,10" Grid.Column="1">
            <Button x:Name="btnCalculate" Content="Вычислить" Width="100" Margin="5" Padding="5" Click="btnCalculate_Click"/>
            <Button x:Name="btnClear" Content="Очистить" Width="100" Margin="5" Padding="5" Click="btnClear_Click" RenderTransformOrigin="0.984,0.767"/>
        </StackPanel>

        <Label Grid.Row="5" Grid.Column="0" Content="Результат:" Margin="5"/>
        <TextBox x:Name="txtResult" Grid.Row="5" Grid.Column="1" Height="30" Margin="5" Padding="5" 
                 IsReadOnly="True" Background="LightYellow"/>


        <Image Grid.Row="0" 
               Source="/Images/image2.png" Stretch="Uniform" 
                Margin="30,45,30,10" ToolTip="Условная функция" Grid.Column="1"/>
    </Grid>
</Page>