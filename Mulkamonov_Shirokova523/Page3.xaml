<Page x:Class="Mulkamonov_Shirokova_523.Pages.Page3"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:wf="clr-namespace:System.Windows.Forms;assembly=System.Windows.Forms"
      Title="Page3" Height="700" Width="900"
      Loaded="Page_Loaded">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <Image Grid.Row="0" 
       Source="/Images/image3.png" Stretch="Uniform" 
       Margin="25,28,30,27" ToolTip="Функция для табулирования" Grid.Column="1"/>

        <Label Grid.Row="1" Grid.Column="0" Content="a:" Margin="5"/>
        <TextBox x:Name="txtA" Grid.Row="1" Grid.Column="1" Width="250" Height="30" Margin="5"/>

        <Label Grid.Row="2" Grid.Column="0" Content="b:" Margin="5"/>
        <TextBox x:Name="txtB" Grid.Row="2" Grid.Column="1" Width="250" Height="30" Margin="5"/>

        <Label Grid.Row="3" Grid.Column="0" Content="c:" Margin="5"/>
        <TextBox x:Name="txtC" Grid.Row="3" Grid.Column="1" Width="250" Height="30" Margin="5"/>

        <Label Grid.Row="4" Grid.Column="0" Content="x₀:" Margin="5"/>
        <TextBox x:Name="txtX0" Grid.Row="4" Grid.Column="1" Width="250" Height="30" Margin="5" ToolTip="Введите десятичное число"/>

        <Label Grid.Row="5" Grid.Column="0" Content="xₖ:" Margin="5"/>
        <TextBox x:Name="txtXk" Grid.Row="5" Grid.Column="1" Width="250" Height="30" Margin="5"/>

        <Label Grid.Row="6" Grid.Column="0" Content="dx:" Margin="5"/>
        <TextBox x:Name="txtDx" Grid.Row="6" Grid.Column="1" Width="250" Height="30" Margin="5"/>

        <StackPanel Grid.Row="7" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
            <Button x:Name="btnCalculate" Content="Вычислить" Width="100" Height="30" Margin="5" Click="btnCalculate_Click"/>
            <Button x:Name="btnClear" Content="Очистить" Width="100" Height="30" Margin="5" Click="btnClear_Click"/>
            <Button x:Name="btnGraph" Content="Построить график" Width="120" Height="30" Margin="5" Click="btnGraph_Click"/>
        </StackPanel>

        <Label Grid.Row="8" Grid.Column="0" Content="Результаты:" Margin="5" VerticalAlignment="Top"/>
        <ListBox x:Name="lstResults" Grid.Row="8" Grid.Column="1" Height="150" Margin="5" Background="LightYellow"/>

        <Label Grid.Row="8" Grid.Column="1" Content="График:" Margin="330,18,-120,0" VerticalAlignment="Top"/>
        <ContentControl x:Name="chartContainer" Grid.Row="8" Grid.Column="1" Margin="377,10,-344,0" Grid.RowSpan="2"/>
    </Grid>
</Page>