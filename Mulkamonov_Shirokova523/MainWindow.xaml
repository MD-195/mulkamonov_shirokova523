<Window x:Class="Mulkamonov_Shirokova_523.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Практическая работа 4 Мулкамонов Широкова" 
        Height="650" Width="900"
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
            <Button x:Name="btnPage1" Content="Страница 1" Width="100" Height="30" Margin="5" Click="btnPage1_Click"/>
            <Button x:Name="btnPage2" Content="Страница 2" Width="100" Height="30" Margin="5" Click="btnPage2_Click"/>
            <Button x:Name="btnPage3" Content="Страница 3" Width="100" Height="30" Margin="5" Click="btnPage3_Click"/>
        </StackPanel>

        <Frame x:Name="MainFrame" Grid.Row="1" NavigationUIVisibility="Hidden"/>
    </Grid>
</Window>